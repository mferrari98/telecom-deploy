#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_DIR="${ROOT_DIR}/backups/${TIMESTAMP}"
DATA_DIR="${ROOT_DIR}/data"

echo "[info] Iniciando backup en ${BACKUP_DIR}"
mkdir -p "${BACKUP_DIR}"

for dir in spa reportes reportes-logs; do
  src="${DATA_DIR}/${dir}"
  if [ ! -d "${src}" ]; then
    echo "[warn] ${src} no existe, saltando"
    continue
  fi
  cp -a "${src}" "${BACKUP_DIR}/${dir}"
  echo "[info] ${src} -> ${BACKUP_DIR}/${dir}"
done

KEEP_DAYS="${BACKUP_KEEP_DAYS:-30}"
deleted=0
while IFS= read -r old_backup; do
  rm -rf "${old_backup}"
  deleted=$((deleted + 1))
done < <(find "${ROOT_DIR}/backups" -maxdepth 1 -mindepth 1 -type d -mtime "+${KEEP_DAYS}" 2>/dev/null)

if [ "${deleted}" -gt 0 ]; then
  echo "[info] Eliminados ${deleted} backups con mas de ${KEEP_DAYS} dias"
fi

echo "[info] Backup completado: ${BACKUP_DIR}"
