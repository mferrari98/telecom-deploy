#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "${ROOT_DIR}/scripts/common.sh"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
RESET='\033[0m'

warn_insecure_credentials

check_repo() {
  local name="$1"
  local dir="$2"
  local ref="$3"

  if [ ! -d "${dir}/.git" ]; then
    echo -e "${RED}[error]${RESET} ${name}: no encontrado (${dir})"
    return
  fi

  local branch
  branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD)"

  local dirty=0
  if [ -n "$(git -C "$dir" status --porcelain)" ]; then
    dirty=1
  fi

  git -C "$dir" fetch origin "$ref" >/dev/null 2>&1 || true

  local upstream
  upstream="$(git -C "$dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "origin/${ref}")"

  local behind ahead
  read -r behind ahead < <(git -C "$dir" rev-list --left-right --count "${upstream}...HEAD" 2>/dev/null || echo "0 0")

  echo -e "${BLUE}${name}${RESET} (${branch})"

  if [ "$dirty" -eq 1 ]; then
    echo -e "  ${YELLOW}Cambios locales sin commitear${RESET}"
  fi

  if [ "$behind" -gt 0 ] && [ "$ahead" -gt 0 ]; then
    echo -e "  ${YELLOW}Divergente${RESET} — ${behind} detras, ${ahead} adelante"
  elif [ "$behind" -gt 0 ]; then
    echo -e "  ${YELLOW}${behind} commit(s) nuevos en remoto${RESET}"
  elif [ "$ahead" -gt 0 ]; then
    echo -e "  ${YELLOW}${ahead} commit(s) locales sin push${RESET}"
  else
    echo -e "  ${GREEN}Actualizado${RESET}"
  fi

  # Commitear cambios locales
  if [ "$dirty" -eq 1 ]; then
    echo -ne "  Commitear y subir cambios? (s/n) "
    read -r respuesta
    if [ "$respuesta" = "s" ]; then
      echo -ne "  Mensaje del commit: "
      read -r mensaje
      if [ -z "$mensaje" ]; then
        mensaje="actualizar $(date +%Y-%m-%d)"
      fi
      git -C "$dir" add -A
      git -C "$dir" commit -m "$mensaje"
      if git -C "$dir" push origin "$ref" >/dev/null 2>&1; then
        echo -e "  ${GREEN}Commit y push ok${RESET}"
      else
        echo -e "  ${RED}Push fallo${RESET}"
      fi
    fi
  fi

  # Bajar cambios remotos
  if [ "$behind" -gt 0 ] && [ "$dirty" -eq 0 ]; then
    echo -ne "  Bajar cambios? (s/n) "
    read -r respuesta
    if [ "$respuesta" = "s" ]; then
      if git -C "$dir" pull --ff-only origin "$ref" >/dev/null 2>&1; then
        echo -e "  ${GREEN}Pull ok${RESET}"
      else
        echo -e "  ${RED}Pull fallo (puede requerir merge manual)${RESET}"
      fi
    fi
  fi

  # Subir commits locales
  if [ "$dirty" -eq 0 ] && [ "$ahead" -gt 0 ]; then
    echo -ne "  Subir cambios? (s/n) "
    read -r respuesta
    if [ "$respuesta" = "s" ]; then
      if git -C "$dir" push origin "$ref" >/dev/null 2>&1; then
        echo -e "  ${GREEN}Push ok${RESET}"
      else
        echo -e "  ${RED}Push fallo${RESET}"
      fi
    fi
  fi

  echo
}

echo -e "${BLUE}Revisando repos...${RESET}\n"

check_repo "telecom-deploy" "$ROOT_DIR" "main"
check_repo "telecom-spa" "${SOURCES_DIR}/telecom-spa" "$SPA_REF"
check_repo "telecom-reportespiolis" "${SOURCES_DIR}/telecom-reportespiolis" "$REPORTES_REF"
check_repo "telecom-informe-agua" "${SOURCES_DIR}/telecom-informe-agua" "$INFORME_AGUA_REF"

echo -e "Para redesplegar: ${BLUE}docker compose -p webtelecom up -d --build --remove-orphans${RESET}"
