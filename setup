#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "${ROOT_DIR}/scripts/common.sh"

warn_insecure_credentials

SPA_DIR="${SOURCES_DIR}/telecom-spa"
REPORTES_DIR="${SOURCES_DIR}/telecom-reportespiolis"
INFORME_AGUA_DIR="${SOURCES_DIR}/telecom-informe-agua"

mkdir -p "${SOURCES_DIR}"

clone_repo() {
  local url="$1"
  local ref="$2"
  local dir="$3"
  local name
  name="$(basename "$dir")"

  if [ -d "${dir}/.git" ]; then
    echo "[info] ${name} ya existe, salteando"
    return
  fi

  echo "[info] Clonando ${name} (${ref})"
  git clone --branch "$ref" --single-branch "$url" "$dir"
}

clone_repo "$SPA_REPO_URL" "$SPA_REF" "$SPA_DIR"
clone_repo "$REPORTES_REPO_URL" "$REPORTES_REF" "$REPORTES_DIR"
clone_repo "$INFORME_AGUA_REPO_URL" "$INFORME_AGUA_REF" "$INFORME_AGUA_DIR"

DATA_SPA_DIR="${ROOT_DIR}/data/spa"
DATA_REPORTES_DIR="${ROOT_DIR}/data/reportes"
DATA_REPORTES_LOGS_DIR="${ROOT_DIR}/data/reportes-logs"
DATA_INFORME_AGUA_DIR="${ROOT_DIR}/data/informe-agua"

mkdir -p "${DATA_SPA_DIR}" "${DATA_REPORTES_DIR}" "${DATA_REPORTES_LOGS_DIR}" "${DATA_INFORME_AGUA_DIR}"

# Asegurar que el user node (uid 1000) pueda escribir en los volumenes
for dir in "${DATA_SPA_DIR}" "${DATA_REPORTES_DIR}" "${DATA_REPORTES_LOGS_DIR}" "${DATA_INFORME_AGUA_DIR}"; do
  if [ ! -w "${dir}" ]; then
    echo "[warn] ${dir} no es escribible, intentando corregir permisos..."
    sudo chown -R "$(id -u):$(id -g)" "${dir}" 2>/dev/null \
      || echo "[error] No se pudo corregir ${dir}. Ejecuta: sudo chown -R \$(id -u):\$(id -g) ${dir}"
  fi
done

if [ ! -f "${DATA_SPA_DIR}/users.json" ]; then
  cp "${SPA_DIR}/data/spa/users.json" "${DATA_SPA_DIR}/users.json"
  echo "[info] Creado ${DATA_SPA_DIR}/users.json"
fi

if [ ! -f "${REPORTES_DIR}/.env" ]; then
  if [ -f "${REPORTES_DIR}/example-env" ]; then
    cp "${REPORTES_DIR}/example-env" "${REPORTES_DIR}/.env"
    echo "[info] Creado ${REPORTES_DIR}/.env desde example-env"
  elif [ -f "${REPORTES_DIR}/.env.example" ]; then
    cp "${REPORTES_DIR}/.env.example" "${REPORTES_DIR}/.env"
    echo "[info] Creado ${REPORTES_DIR}/.env desde .env.example"
  fi
fi

echo
echo "[info] Setup completo. Para levantar los contenedores:"
echo "  docker compose -p webtelecom up -d --build --remove-orphans"
